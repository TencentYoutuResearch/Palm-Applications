# PalmDestiny 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 注意：.env 文件包含密钥，禁止提交到 Git

# ===== 服务配置 =====
PORT=8000
BASE_PATH=/palm-destiny

# ===== 模型配置 =====
# MODEL_TYPE: "qwen" 或 "hunyuan"
MODEL_TYPE=hunyuan
# DEPLOYMENT_TYPE: "local"（Ollama 本地部署）或 "cloud"（云端 API）
DEPLOYMENT_TYPE=cloud

# ===== 腾讯云混元 API 密钥（替换为你的云端大模型密钥） =====
# HUNYUAN_SECRET_ID=你的混元SecretId
# HUNYUAN_SECRET_KEY=你的混元SecretKey

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./palmistry.db

# ===== 上传目录 =====
UPLOAD_DIR=./static/uploads

# ===== CORS（替换为你的实际部署域名） =====
CORS_ORIGINS=["http://localhost:8000"]

# ===== API Key 认证（前后端之间，用 openssl rand -base64 32 生成） =====
# API_KEY=你的APIKey

# ===== 速率限制（每 IP 每分钟最大请求数） =====
RATE_LIMIT_PER_MINUTE=30

# ===== 你的刷掌算法服务配置（Bearer Token 鉴权） =====
# 替换为你的刷掌识别算法服务网址
# PALM_API_BASE_URL=https://your-palm-api-host.example.com
# 替换为你的刷掌算法 Bearer Token
# PALM_API_BEARER_TOKEN=your-bearer-token-here
# 替换为你的掌纹注册 API 路径
# PALM_REGISTER_PATH=/your-palm-register-api-path
# 替换为你的掌纹检索 API 路径
# PALM_SEARCH_PATH=/your-palm-search-api-path
PALM_API_TIMEOUT=15
