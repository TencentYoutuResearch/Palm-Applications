# GlassWiper 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 注意：.env 文件包含密钥，禁止提交到 Git

# 服务端口（容器/生产建议使用 8000；本地开发可用 3000）
PORT=8000

# 你的刷掌算法服务网址（替换为你的掌纹识别服务域名）
PALM_HOST=your-palm-api-host.example.com

# 你的刷掌算法 Bearer Token（替换为你的服务鉴权凭据）
# PALM_BEARER_TOKEN=your-bearer-token-here

# 掌纹注册用户ID（注册时服务端自动注入，不暴露在前端）
# PALM_USER_ID=your-user-id

# API Key（前端与后端之间的认证密钥，用 openssl rand -base64 32 生成）
# API_KEY=your-api-key-here

# CORS 允许的来源（逗号分隔，替换为你的实际部署域名）
CORS_ORIGINS=http://localhost:3000,https://your-domain.example.com

# 速率限制（每分钟每IP最大请求数）
RATE_LIMIT_PER_MINUTE=30
