# palm-racer 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===== Palm API =====
PALM_APP_ID=0
PALM_SECRET_ID=your-secret-id-here
PALM_SECRET_KEY=your-secret-key-here
PALM_HOST=your-palm-api-host.example.com

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your-db-password-here
DB_NAME=palm_racer

# ===== Redis =====
REDIS_ADDRESS=localhost:6380
REDIS_PASSWORD=

# ===== 静态文件路径 =====
# 前端构建产物目录，默认相对于 server 可执行文件
STATIC_ROOT=../web/dist
