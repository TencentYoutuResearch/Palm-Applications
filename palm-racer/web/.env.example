# Palm Racer Web 本地开发环境变量(占位示例)
#
# 用法:
#   1. cp .env.example .env.local
#   2. 按需修改 .env.local
#   3. Vite 会自动加载 .env.local(已在 .gitignore 中,不入库)

# === 后端 API 基础地址 ===
# 开发时指向本地后端;生产构建不需要设置(走同域 /api)
VITE_API_BASE_URL=http://localhost:8080

# === 预览/调试配置 ===
# 是否开启摄像头自动启动(true/false)
VITE_AUTO_START_CAMERA=true

# 日志级别(debug / info / warn / error)
VITE_LOG_LEVEL=info

# === 手掌识别适配器 ===
# 强制使用指定适配器(wasm / native / auto)
# auto:运行时根据 isNative() 自动选择
VITE_HAND_TRACKER=auto
